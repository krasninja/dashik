<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Dashik.Sdk.ViewModels"
        xmlns:mvvm="clr-namespace:Dashik.Sdk.Mvvm"
        mc:Ignorable="d"
        d:DesignWidth="300"
        d:DesignHeight="100"
        x:Class="Dashik.Sdk.Views.MessageBoxWindow"
        x:DataType="viewModels:MessageBoxViewModel"
        Title="{Binding Caption}"
        Width="300"
        Height="100"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        CanMaximize="False"
        CanMinimize="False"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Dashik.Sdk/Resources/MessageBox.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid RowDefinitions="*,Auto" Margin="20">
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <Image Source="{Binding Icon}" Grid.Column="0" Margin="0,0,15,0" Width="32" Height="32" />
            <TextBlock
                Grid.Column="1"
                Text="{Binding Message}"
                TextWrapping="Wrap"
                VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button
                Content="OK"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.OK}"
                IsVisible="{Binding ShowOkButton}" />
            <Button
                Content="Yes"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.Yes}"
                IsVisible="{Binding ShowYesButton}" />
            <Button
                Content="No"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.No}"
                IsVisible="{Binding ShowNoButton}" />
            <Button
                Content="Cancel"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.Cancel}"
                IsVisible="{Binding ShowCancelButton}" />
            <Button
                Content="Abort"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.Abort}"
                IsVisible="{Binding ShowAbortButton}" />
            <Button
                Content="Retry"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.Retry}"
                IsVisible="{Binding ShowRetryButton}" />
            <Button
                Content="Ignore"
                Command="{Binding ActionSelectCommand}"
                CommandParameter="{x:Static mvvm:DialogResult.Ignore}"
                IsVisible="{Binding ShowIgnoreButton}" />
        </StackPanel>
    </Grid>
</Window>
