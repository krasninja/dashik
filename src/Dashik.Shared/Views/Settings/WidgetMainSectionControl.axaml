<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:Dashik.Shared.ViewModels.Settings"
             xmlns:models="clr-namespace:Dashik.Sdk.Models;assembly=Dashik.Sdk"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="Dashik.Shared.Views.Settings.WidgetMainSettingsControl"
             x:DataType="settings:WidgetMainSectionViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </UserControl.Styles>

    <Grid RowSpacing="3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0">Update interval:</TextBlock>
        <StackPanel Orientation="Vertical" Grid.Column="1" Grid.Row="0">
            <TimePicker
                ClockIdentifier="24HourClock"
                UseSeconds="True"
                SelectedTime="{Binding ((models:WidgetMainSettings)Settings).UpdateInterval}" />
            <TextBlock FontStyle="Italic">Hours / minutes / seconds</TextBlock>
        </StackPanel>

        <TextBlock Grid.Column="0" Grid.Row="1">Use custom title:</TextBlock>
        <CheckBox
            Grid.Column="1"
            Grid.Row="1"
            IsChecked="{Binding ((models:WidgetMainSettings)Settings).UseCustomTitle}" />

        <TextBlock Grid.Column="0" Grid.Row="2">Custom title:</TextBlock>
        <TextBox
            Grid.Column="1"
            Grid.Row="2"
            Text="{Binding ((models:WidgetMainSettings)Settings).CustomTitle}" />

        <TextBlock Grid.Column="0" Grid.Row="3">Proxy server:</TextBlock>
        <StackPanel Orientation="Vertical" Grid.Column="1" Grid.Row="3">
            <TextBox
                Text="{Binding ((models:WidgetMainSettings)Settings).WebProxy}" />
            <TextBlock FontStyle="Italic">Examples: socks5://127.0.0.1:1080</TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
