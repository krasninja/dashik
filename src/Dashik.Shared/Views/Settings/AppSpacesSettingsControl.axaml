<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Dashik.Shared.ViewModels.Settings"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="Dashik.Shared.Views.Settings.AppSpacesSettingsControl"
             x:DataType="viewModels:AppSpacesSettingsViewModel">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Dashik.Shared/Resources/FontAwesome.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding AddSpaceCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <PathIcon Data="{StaticResource FontAwesomeSolidPlus}" Margin="0,0,5,0" />
                                <TextBlock>Add</TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding RemoveSpaceCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <PathIcon Data="{StaticResource FontAwesomeSolidMinus}" Margin="0,0,5,0" />
                                <TextBlock>Remove</TextBlock>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </DockPanel>
        </StackPanel>

        <DataGrid
            Grid.Row="1"
            CanUserReorderColumns="False"
            CanUserResizeColumns="False"
            CanUserSortColumns="False"
            SelectedItem="{Binding SelectedSpace}"
            ItemsSource="{Binding ((viewModels:AppSettingsViewModel)Settings).Spaces}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Width="120" IsReadOnly="True" Binding="{Binding Id}" />
                <DataGridTextColumn Header="Name" Width="*" Binding="{Binding Name}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
